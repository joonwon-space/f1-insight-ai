# MongoDB
# Use "mongodb" (service name) when running via Docker Compose
# Use "localhost" when running services directly on host
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=f1_insight

# Elasticsearch
# Use "elasticsearch" (service name) when running via Docker Compose
# Use "localhost" when running services directly on host
ELASTICSEARCH_URL=http://elasticsearch:9200

# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend (Vite)
# Used by the browser to call the backend API
VITE_API_URL=http://localhost:8000

# Unsplash (article images)
UNSPLASH_ACCESS_KEY=

# Cloudflare Tunnel (remote access)
CLOUDFLARE_TUNNEL_TOKEN=

# Error Alerts (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Logging (set to false for human-readable logs in development)
JSON_LOGS=true
