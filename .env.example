# MongoDB
# Use "mongodb" (service name) when running via Docker Compose
# Use "localhost" when running services directly on host
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=f1_insight

# Elasticsearch
# Use "elasticsearch" (service name) when running via Docker Compose
# Use "localhost" when running services directly on host
ELASTICSEARCH_URL=http://elasticsearch:9200

# LLM
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
# Use "http://f1-backend:8000" for server-side calls inside Docker network
# Use "http://localhost:8000" for client-side (browser) calls
NEXT_PUBLIC_API_URL=http://localhost:8000

# Getty Images
GETTY_EMBED_API_KEY=
